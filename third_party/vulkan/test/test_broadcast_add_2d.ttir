// Test: true 2D broadcast add — x[M,N] + bias[N] → out[M,N]
// Uses expand_dims + broadcast to create 2D pointer tensors.
// M=4 rows, N=8 cols — small sizes to verify correctness.
module {
  tt.func public @broadcast_add_2d_kernel(
      %x_ptr: !tt.ptr<f32>, %bias_ptr: !tt.ptr<f32>,
      %out_ptr: !tt.ptr<f32>, %M: i32, %N: i32) {
    // Row indices: [0,1,2,3]
    %rows = tt.make_range {start = 0 : i32, end = 4 : i32} : tensor<4xi32>
    // Col indices: [0,1,2,3,4,5,6,7]
    %cols = tt.make_range {start = 0 : i32, end = 8 : i32} : tensor<8xi32>

    // Expand rows: [4] → [4,1]
    %rows_2d = tt.expand_dims %rows {axis = 1 : i32} : tensor<4xi32> -> tensor<4x1xi32>
    // Broadcast rows: [4,1] → [4,8]
    %rows_bc = tt.broadcast %rows_2d : tensor<4x1xi32> -> tensor<4x8xi32>

    // Expand cols: [8] → [1,8]
    %cols_2d = tt.expand_dims %cols {axis = 0 : i32} : tensor<8xi32> -> tensor<1x8xi32>
    // Broadcast cols: [1,8] → [4,8]
    %cols_bc = tt.broadcast %cols_2d : tensor<1x8xi32> -> tensor<4x8xi32>

    // x offsets = row * N + col (linearized 2D indexing)
    %N_splat = tt.splat %N : i32 -> tensor<4x8xi32>
    %row_off = arith.muli %rows_bc, %N_splat : tensor<4x8xi32>
    %x_offs = arith.addi %row_off, %cols_bc : tensor<4x8xi32>

    // Load x[row, col]
    %x_base = tt.splat %x_ptr : !tt.ptr<f32> -> tensor<4x8x!tt.ptr<f32>>
    %x_ptrs = tt.addptr %x_base, %x_offs : tensor<4x8x!tt.ptr<f32>>, tensor<4x8xi32>
    %x = tt.load %x_ptrs : tensor<4x8x!tt.ptr<f32>>

    // Load bias[col] — 1D, then broadcast to 2D
    %bias_base = tt.splat %bias_ptr : !tt.ptr<f32> -> tensor<8x!tt.ptr<f32>>
    %bias_ptrs = tt.addptr %bias_base, %cols : tensor<8x!tt.ptr<f32>>, tensor<8xi32>
    %bias_1d = tt.load %bias_ptrs : tensor<8x!tt.ptr<f32>>
    %bias_2d_pre = tt.expand_dims %bias_1d {axis = 0 : i32} : tensor<8xf32> -> tensor<1x8xf32>
    %bias_2d = tt.broadcast %bias_2d_pre : tensor<1x8xf32> -> tensor<4x8xf32>

    // out = x + bias
    %result = arith.addf %x, %bias_2d : tensor<4x8xf32>

    // Store out[row, col]
    %out_base = tt.splat %out_ptr : !tt.ptr<f32> -> tensor<4x8x!tt.ptr<f32>>
    %out_ptrs = tt.addptr %out_base, %x_offs : tensor<4x8x!tt.ptr<f32>>, tensor<4x8xi32>
    tt.store %out_ptrs, %result : tensor<4x8x!tt.ptr<f32>>

    tt.return
  }
}
