// Phase 2 test: transpose — out[j,i] = x[i,j]
// Simple: load 16x16, transpose, store
// Uses flat 1D addressing to avoid 2D pointer patterns
module {
  tt.func public @transpose_kernel(
      %x_ptr: !tt.ptr<f32>, %out_ptr: !tt.ptr<f32>,
      %M: i32, %N: i32) {
    // Load 256 elements as flat
    %range = tt.make_range {start = 0 : i32, end = 256 : i32} : tensor<256xi32>
    %xb = tt.splat %x_ptr : !tt.ptr<f32> -> tensor<256x!tt.ptr<f32>>
    %xp = tt.addptr %xb, %range : tensor<256x!tt.ptr<f32>>, tensor<256xi32>
    %x_flat = tt.load %xp : tensor<256x!tt.ptr<f32>>

    // Reshape to 16x16
    %x = tt.reshape %x_flat : tensor<256xf32> -> tensor<16x16xf32>

    // Transpose
    %xt = tt.trans %x {order = array<i32: 1, 0>} : tensor<16x16xf32> -> tensor<16x16xf32>

    // Flatten back
    %out_flat = tt.reshape %xt : tensor<16x16xf32> -> tensor<256xf32>

    // Store
    %ob = tt.splat %out_ptr : !tt.ptr<f32> -> tensor<256x!tt.ptr<f32>>
    %op = tt.addptr %ob, %range : tensor<256x!tt.ptr<f32>>, tensor<256xi32>
    tt.store %op, %out_flat : tensor<256x!tt.ptr<f32>>
    tt.return
  }
}
