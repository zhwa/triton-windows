// Minimal vector-add TTIR for debugging the Triton compilation pipeline.
// No loop, just load + add + store — the simplest possible kernel.
//
// Debug steps:
//   1. Parse/verify:   triton-opt debug-vecadd.ttir -verify-diagnostics
//   2. Canonicalize:   triton-opt debug-vecadd.ttir -canonicalize
//   3. TTIR → TTGIR:   triton-opt debug-vecadd.ttir -convert-triton-to-tritongpu="target=cuda:80 num-warps=4 threads-per-warp=32 num-ctas=1"
//
module {
  tt.func public @vecadd_kernel(%x: !tt.ptr<f32>, %y: !tt.ptr<f32>, %out: !tt.ptr<f32>, %N: i32) {
    // Get block ID
    %pid = tt.get_program_id x : i32

    // Compute offsets: pid * 256 + [0..255]
    %c256 = arith.constant 256 : i32
    %base = arith.muli %pid, %c256 : i32
    %range = tt.make_range {end = 256 : i32, start = 0 : i32} : tensor<256xi32>
    %base_splat = tt.splat %base : i32 -> tensor<256xi32>
    %offsets = arith.addi %base_splat, %range : tensor<256xi32>

    // Mask: offsets < N
    %N_splat = tt.splat %N : i32 -> tensor<256xi32>
    %mask = arith.cmpi slt, %offsets, %N_splat : tensor<256xi32>

    // Pointer arithmetic
    %x_ptrs = tt.splat %x : !tt.ptr<f32> -> tensor<256x!tt.ptr<f32>>
    %x_addrs = tt.addptr %x_ptrs, %offsets : tensor<256x!tt.ptr<f32>>, tensor<256xi32>
    %y_ptrs = tt.splat %y : !tt.ptr<f32> -> tensor<256x!tt.ptr<f32>>
    %y_addrs = tt.addptr %y_ptrs, %offsets : tensor<256x!tt.ptr<f32>>, tensor<256xi32>
    %out_ptrs = tt.splat %out : !tt.ptr<f32> -> tensor<256x!tt.ptr<f32>>
    %out_addrs = tt.addptr %out_ptrs, %offsets : tensor<256x!tt.ptr<f32>>, tensor<256xi32>

    // Load x and y
    %zero = arith.constant 0.000000e+00 : f32
    %zeros = tt.splat %zero : f32 -> tensor<256xf32>
    %x_vals = tt.load %x_addrs, %mask, %zeros : tensor<256x!tt.ptr<f32>>
    %y_vals = tt.load %y_addrs, %mask, %zeros : tensor<256x!tt.ptr<f32>>

    // Add
    %result = arith.addf %x_vals, %y_vals : tensor<256xf32>

    // Store
    tt.store %out_addrs, %result, %mask : tensor<256x!tt.ptr<f32>>
    tt.return
  }
}
